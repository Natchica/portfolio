{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Nathan's Portfolio - Monorepo",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && cargo watch -x run",
    "dev:frontend": "cd frontend && trunk serve",
    "build": "cd frontend && trunk build --release",
    "build:backend": "cd backend && cargo build --release"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["portfolio", "rust", "leptos", "axum", "wasm"],
  "author": "Nathan",
  "license": "MIT"
}
